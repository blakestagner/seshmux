{
  "name": "seshmux",
  "version": "0.1.4",
  "description": "Local-first mission control for AI coding agents (Claude Code + Codex)",
  "bin": {
    "seshmux": "bin/seshmux.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node -e \"require('./daemon/ensure').ensureDaemon()\"",
    "dev": "PORT=${PORT:-4800} tsx server/index.ts",
    "build": "bash scripts/build-standalone.sh",
    "start": "node bin/seshmux.js",
    "lint:styles": "bash scripts/lint-styles.sh",
    "test": "npm run lint:styles && vitest run",
    "prepack": "bash scripts/build-standalone.sh"
  },
  "files": [
    "bin/",
    "daemon/",
    ".next/standalone/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "tui",
    "terminal",
    "session-manager",
    "local-first",
    "developer-tools"
  ],
  "author": "blakestagner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blakestagner/seshmux.git"
  },
  "homepage": "https://github.com/blakestagner/seshmux#readme",
  "bugs": {
    "url": "https://github.com/blakestagner/seshmux/issues"
  },
  "type": "commonjs",
  "dependencies": {
    "@fastify/websocket": "^11.3.0",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "fastify": "^5.10.0",
    "marked": "^18.0.5",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "5.8.2",
    "vitest": "^3.2.7"
  }
}
